      "sourceText": "Clean Architecture 모듈 경계 설계해줘",
      "expectedIntent": "architecture",
      "expectedCategory": "architecture",
      "minimumSections": ["작업 목표", "실행 계획", "검증 기준", "Architecture Diagram", "Module Boundary", "Tradeoff Analysis", "Validation Criteria"],
      "qualityExpectations": {
        "sourceMax": 35,
        "optimizedMin": 90,
